# SQLite file (default: ./data/owntube.db)
DATABASE_PATH=./data/owntube.db

# Primary Piped API base (no trailing slash).
# Set to "disabled" to skip Piped entirely and use only Invidious.
# Public instances list: https://piped-instances.kavin.rocks/
PIPED_BASE_URL=https://pipedapi.kavin.rocks

# Invidious fallback (no trailing slash).
# Set this to a reliable instance — or your own self-hosted one.
# Self-hosting guide: docs/SELF-HOSTING.md
# Public instances list: https://api.invidious.io/
# INVIDIOUS_BASE_URL=https://your-invidious.example

# ── Self-hosted Invidious (recommended for local dev) ─────────────────────────
# Run:  bash scripts/setup-invidious.sh
# Then uncomment:
# PIPED_BASE_URL=disabled
# INVIDIOUS_BASE_URL=http://localhost:3001

# debug | info | warn | error
LOG_LEVEL=info
# Process-wide upstream limiter (OwnTube side, not Invidious/Piped side)
# UPSTREAM_RATE_LIMIT_MAX_REQUESTS=60
# UPSTREAM_RATE_LIMIT_WINDOW_MS=60000

# Recommendation score debug: logs to stdout and logs/recommendation-debug.ndjson
# OWNTUBE_DEBUG_RECOMMENDATIONS=1
# Optional absolute or cwd-relative path:
# OWNTUBE_RECOMMENDATION_LOG_PATH=./logs/my-recs.ndjson

# Next.js (disable telemetry in containers)
NEXT_TELEMETRY_DISABLED=1

# Auth.js secret for JWT sessions
AUTH_SECRET=change-me-in-production
